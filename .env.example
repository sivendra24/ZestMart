APP_ENV=development
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=
JWT_SECRET_KEY=
JWT_EXPIRATION_HOURS=12
JWT_COOKIE_NAME=zestmart_session
JWT_COOKIE_DOMAIN=
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAMESITE=Lax
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=zestmart
RATELIMIT_STORAGE_URI=memory://
RATELIMIT_HEADERS_ENABLED=true
RATELIMIT_STRATEGY=fixed-window
LOGIN_RATE_LIMIT=10 per 15 minutes
OTP_SEND_RATE_LIMIT=5 per 10 minutes
OTP_VERIFY_RATE_LIMIT=10 per 10 minutes
OTP_EXPIRY_MINUTES=5
OTP_RATE_LIMIT_WINDOW_MINUTES=60
OTP_MAX_SENDS_PER_WINDOW=5
OTP_MAX_VERIFICATION_ATTEMPTS=5
MAX_IMAGE_PIXELS=20000000
MOCK_OTP_ENABLED=true
SMS_PROVIDER=twilio
SMS_DEFAULT_COUNTRY_CODE=+91
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=
TWILIO_MESSAGING_SERVICE_SID=
ALLOWED_IMAGE_EXTENSIONS=png,jpg,jpeg,webp
ALLOWED_IMAGE_MIME_TYPES=image/png,image/jpeg,image/webp
MAX_CONTENT_LENGTH_MB=5
CORS_ORIGINS=http://127.0.0.1:5000,http://localhost:5000
FLASK_DEBUG=false
LOG_LEVEL=INFO
TRUST_PROXY_COUNT=1
PORT=5000
